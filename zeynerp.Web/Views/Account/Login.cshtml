@model LoginViewModel
@{
    Layout = "_Layout.cshtml";
}

<div class="card-title-sign mt-3 text-end">
    <h2 class="title text-uppercase font-weight-bold m-0"><i
            class="bx bx-user-circle me-1 text-6 position-relative top-5"></i> Oturum Aç</h2>
</div>
<div class="card-body">
    <form id="form" asp-action="Login" method="post">
        <div class="form-group mb-3">
            <label>E-Posta</label>
            <div class="input-group">
                <input asp-for="Email" type="email" class="form-control form-control-lg" required />
                <span class="input-group-text">
                    <i class="bx bx-envelope text-4"></i>
                </span>
            </div>
        </div>

        <div class="form-group mb-3">
            <div class="clearfix">
                <label class="float-start">Şifre</label>
                <a href="pages-recover-password.html" class="float-end">Şifrenizi mi unuttunuz?</a>
            </div>
            <div class="input-group">
                <input asp-for="Password" type="password" class="form-control form-control-lg" required />
                <span class="input-group-text">
                    <i class="bx bx-lock text-4"></i>
                </span>
            </div>
        </div>

        <div class="row">
            <div class="col-sm-8">

            </div>
            <div class="col-sm-4 text-end">
                <button type="submit" class="btn btn-primary mt-2">Oturum Aç</button>
            </div>
        </div>

        <span class="mt-3 mb-3 line-thru text-center text-uppercase">
            <span>or</span>
        </span>

        <div class="mb-1 text-center">
            <a class="btn btn-gplus mb-3 ms-1 me-1" href="#">Connect with <i class="fab fa-google"></i></a>
            <a class="btn btn-twitter mb-3 ms-1 me-1" href="#">Connect with <i class="fab fa-twitter"></i></a>
        </div>

        <p class="text-center">Zeynerp'de yeni misiniz? <a asp-action="Register">Hemen Katılın!</a></p>
    </form>
</div>