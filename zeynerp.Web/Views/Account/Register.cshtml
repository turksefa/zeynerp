@model RegisterViewModel
@{
    Layout = "_Layout.cshtml";
}

<div class="card-title-sign mt-3 text-end">
    <h2 class="title text-uppercase font-weight-bold m-0"><i
            class="bx bx-user-circle me-1 text-6 position-relative top-5"></i> Sign Up</h2>
</div>
<div class="card-body">
    <form id="form" asp-action="Register" method="post">
        <div class="form-group mb-3">
            <label>Kullanıcı Ad</label>
            <div class="input-group">
                <input asp-for="UserName" type="text" class="form-control form-control-lg" required />
                <span class="input-group-text">
                    <i class="bx bx-user text-4"></i>
                </span>
            </div>
        </div>

        <div class="form-group mb-3">
            <label>E-Posta</label>
            <div class="input-group">
                <input asp-for="Email" type="email" class="form-control form-control-lg" required />
                <span class="input-group-text">
                    <i class="bx bx-envelope text-4"></i>
                </span>
            </div>
        </div>

        <div class="form-group mb-3">
            <label>Şifre</label>
            <div class="input-group">
                <input asp-for="Password" type="password" class="form-control form-control-lg" required />
                <span class="input-group-text">
                    <i class="bx bx-lock-alt text-4"></i>
                </span>
            </div>
        </div>

        <div class="row">
            <div class="col-sm-8">
                <div class="checkbox-custom checkbox-default">
                    <input id="AgreeTerms" name="agreeterms" type="checkbox" required />
                    <label><a href="#" data-bs-toggle="modal" data-bs-target="#exampleModal">Kullanım koşullarını</a>
                        kabul ediyorum.</label>
                    <div class="modal fade" id="exampleModal" tabindex="-1" aria-labelledby="exampleModalLabel"
                        aria-hidden="true">
                        <div class="modal-dialog modal-dialog-centered modal-lg">
                            <div class="modal-content">
                                <div class="modal-header">
                                    <h1 class="modal-title fs-5" id="exampleModalLabel">Kullanım Koşulları</h1>
                                    <button type="button" class="btn-close" data-bs-dismiss="modal"
                                        aria-label="Close"></button>
                                </div>
                                <div class="modal-body">
                                    <p>Lorem ipsum odor amet, consectetuer adipiscing elit. Justo cursus sem, varius cursus
                                    metus montes vel. Consequat ornare feugiat sem felis erat sit aenean. Blandit erat
                                    curae eget bibendum justo. Justo imperdiet curabitur leo conubia nullam elit blandit
                                    nascetur. Cubilia tortor nostra dis pellentesque egestas nullam magna?</p>

                                    <p>Pellentesque vitae dignissim tristique pretium sem consequat imperdiet dui erat.
                                    Posuere inceptos tempor tincidunt purus nascetur. Inceptos eros purus in malesuada
                                    venenatis ipsum. Euismod curae dui ullamcorper lacus litora. Congue proin ad libero
                                    parturient magnis aptent urna nec. Iaculis congue rutrum platea velit facilisis
                                    potenti.</p>
                                </div>
                                <div class="modal-footer p-0">
                                    <button type="button" class="btn btn-primary w-100">Okudum</button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-sm-4 text-end">
                <button type="submit" class="btn btn-primary mt-2">Sign Up</button>
            </div>
        </div>

        <span class="mt-3 mb-3 line-thru text-center text-uppercase">
            <span>or</span>
        </span>

        <div class="mb-1 text-center">
            <a class="btn btn-gplus mb-3 ms-1 me-1" href="#">Connect with <i class="fab fa-google"></i></a>
            <a class="btn btn-twitter mb-3 ms-1 me-1" href="#">Connect with <i class="fab fa-twitter"></i></a>
        </div>

        <p class="text-center">Hesabınız var mı? <a asp-action="Login">Oturum Aç</a></p>

    </form>
</div>